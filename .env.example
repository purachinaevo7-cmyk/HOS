HOS_EXECUTOR=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
HOS_DEFAULT_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
HOS_FREE_TIER_MODE=true
HOS_MAX_AGENT_CALLS=5
HOS_MAX_RETRIES=1
GEMINI_MAX_OUTPUT_TOKENS_DEFAULT=2048
GEMINI_MAX_OUTPUT_TOKENS_CEO=3000
# Legacy override; prefer GEMINI_MAX_OUTPUT_TOKENS_*
HOS_MAX_OUTPUT_TOKENS_PER_AGENT=
HOS_MAX_TOTAL_TOKENS=
HOS_DAILY_RUN_LIMIT=
HOS_MAX_PARALLEL_AGENTS=3
HOS_MAX_RUN_COST=

# Stock Watch V2
DISCORD_NOTIFY_NO_ALERT=false
# Optional official/contracted TOPIX CSV feed. If unset, free fallback providers and ETF median reference are used.
JPX_TOPIX_CSV_URL=
# V2 config files live in skills/investment-agent/config/stock_watch_universe.json and portfolio_policy.json.

# Investment Fact Pipeline: network facts are opt-in; no paid fallback.
HOS_ENABLE_NETWORK_FACTS=false

# Verified investment fact pipeline (free-tier safe)
HOS_FACT_MODE=cached_only
HOS_ENABLE_NETWORK_FACTS=false
HOS_FACT_PACK_ONLY=false
HOS_VERIFIED_LITE_MAX_CALLS=2
HOS_MAX_VERIFIED_ANALYSES_PER_DAY=3
HOS_MAX_AGENT_CALLS=2
# Optional only; pipeline must continue when unset.
EDINET_API_KEY=
